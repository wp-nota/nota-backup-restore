msgstr "Auf automatisch zurücksetzen"

msgid "↺ Recalculate"
msgstr "↺ Neu berechnen"

msgid "Recalculate"
msgstr "Neu berechnen"

msgid "Maximum total file size processed per ZIP request. Auto-calculated based on your server's available memory."
msgstr "Maximale Gesamtdateigröße pro ZIP-Anfrage. Automatisch basierend auf dem verfügbaren Serverspeicher berechnet."

